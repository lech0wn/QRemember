@page
@model MyEventsModel
@{
    ViewData["Title"] = "My Events";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"]</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Playfair+Display:ital,wght@0,600;0,700;1,500&display=swap" rel="stylesheet" />
    <style>
        :root {
            --accent: #B8975A;
            --bg: #FAF9F6;
            --text: #1C1C1C;
            --muted: #8C8C8C;
        }

        * {
            box-sizing: border-box;
        }

        html, body {
            margin: 0;
            min-height: 100%;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: var(--bg);
            color: var(--text);
        }

        .layout {
            max-width: 1000px;
            margin: 0 auto;
            padding: 40px 32px 80px;
        }

        h1.section-title {
            font-family: 'Playfair Display', serif;
            font-weight: 700;
            font-size: 34px;
            color: var(--accent);
            margin: 0 0 28px;
        }

        .event-grid {
            column-count: 2;
            column-gap: 24px;
        }

        .event-card {
            display: block;
            break-inside: avoid;
            margin-bottom: 24px;
            background: var(--text);
            border-radius: 10px;
            overflow: hidden;
            box-shadow: 0 8px 24px rgba(0, 0, 0, 0.15);
            transition: transform 0.12s;
        }

        .event-card:hover {
            transform: translateY(-2px);
        }

        .event-photo-link {
            display: block;
            text-decoration: none;
            cursor: pointer;
        }

        .event-photo {
            width: 100%;
        }

        .event-caption {
            text-align: center;
            padding: 18px 16px 14px;
        }

        .event-caption .event-title {
            font-family: 'Playfair Display', serif;
            font-style: italic;
            font-weight: 500;
            font-size: 16px;
            color: #F5F3EC;
        }

        .event-caption .event-year {
            font-family: 'Inter', sans-serif;
            font-size: 13px;
            color: var(--accent);
        }

        .event-footer {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 10px;
            padding: 0 16px 18px;
        }

        .event-countdown {
            font-family: 'Inter', sans-serif;
            font-size: 11px;
            font-weight: 600;
            letter-spacing: 0.5px;
            text-transform: uppercase;
            color: var(--accent);
        }

        .event-countdown.expired {
            color: #E0857A;
        }

        .cancel-form {
            margin: 0;
        }

        .btn-cancel-event {
            background: none;
            border: 1px solid rgba(245, 243, 236, 0.35);
            border-radius: 20px;
            padding: 6px 12px;
            font-family: 'Inter', sans-serif;
            font-size: 10px;
            font-weight: 600;
            letter-spacing: 0.5px;
            text-transform: uppercase;
            color: #F5F3EC;
            cursor: pointer;
            white-space: nowrap;
        }

        .btn-cancel-event:hover {
            background: #B00020;
            border-color: #B00020;
        }

        .empty-state {
            text-align: center;
            padding: 60px 20px;
            color: var(--muted);
            font-size: 14px;
        }

        @@media (max-width: 640px) {
            .event-grid {
                column-count: 1;
            }
        }
    </style>
</head>
<body>
    <partial name="_EventsNavBar" />

    <div class="layout">
        <h1 class="section-title">Recent Events</h1>

        @if (Model.Events.Count == 0)
        {
            <div class="empty-state">You haven't created any events yet.</div>
        }
        else
        {
            <div class="event-grid">
                @foreach (var ev in Model.Events)
                {
                    <div class="event-card">
                        <a class="event-photo-link" asp-page="EventDetail" asp-route-code="@ev.EventCode">
                            <div class="event-photo" style="height:@(ev.PhotoHeight)px;background:linear-gradient(160deg, @ev.GradientFrom, @ev.GradientTo);"></div>
                            <div class="event-caption">
                                <span class="event-title">@ev.Title</span>
                                <span class="event-year"> &bull; @ev.Year</span>
                            </div>
                        </a>
                        <div class="event-footer">
                            <span class="event-countdown" data-expires-utc="@ev.ExpiresAtUtc.ToString("o")">Calculating&hellip;</span>
                            <form method="post" asp-page-handler="Cancel" asp-route-code="@ev.EventCode" class="cancel-form" data-event-title="@ev.Title">
                                <button type="submit" class="btn-cancel-event">Cancel Event</button>
                            </form>
                        </div>
                    </div>
                }
            </div>
        }
    </div>

    <script>
        (function () {
            var countdowns = document.querySelectorAll('.event-countdown');

            function render() {
                var now = Date.now();
                countdowns.forEach(function (el) {
                    var expires = new Date(el.dataset.expiresUtc).getTime();
                    var remainingMs = expires - now;

                    if (remainingMs <= 0) {
                        el.textContent = 'Expired';
                        el.classList.add('expired');
                        return;
                    }

                    var totalMinutes = Math.floor(remainingMs / 60000);
                    var days = Math.floor(totalMinutes / 1440);
                    var hours = Math.floor((totalMinutes % 1440) / 60);
                    var minutes = totalMinutes % 60;

                    el.textContent = 'Expires in ' + days + 'd ' + hours + 'h ' + minutes + 'm';
                });
            }

            render();
            setInterval(render, 30000);
        })();

        (function () {
            var forms = document.querySelectorAll('.cancel-form');
            forms.forEach(function (form) {
                form.addEventListener('submit', function (e) {
                    var title = form.dataset.eventTitle || 'this event';
                    if (!confirm('Cancel and permanently delete "' + title + '"? This cannot be undone.')) {
                        e.preventDefault();
                    }
                });
            });
        })();
    </script>
</body>
</html>
