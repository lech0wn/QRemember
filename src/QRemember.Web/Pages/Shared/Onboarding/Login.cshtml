@page
@model LoginModel
@{
    ViewData["Title"] = "Log in";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"]</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Playfair+Display:wght@500;600;700&display=swap" rel="stylesheet" />
    <style>
        :root {
            --accent: #B8975A;
            --bg: #FAF9F6;
            --text: #1C1C1C;
            --muted: #8C8C8C;
        }

        * {
            box-sizing: border-box;
        }

        html, body {
            height: 100%;
            margin: 0;
        }

        body {
            position: relative;
            min-height: 100vh;
            font-family: 'Inter', sans-serif;
            display: flex;
            align-items: stretch;
            justify-content: center;
        }

        body::before {
            content: "";
            position: fixed;
            inset: 0;
            background-image: url('/images/auth-pic.jpg');
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
            filter: grayscale(100%);
            z-index: -1;
        }

        .auth-panel {
            width: 520px;
            max-width: 100%;
            min-height: 100vh;
            background: var(--bg);
            box-shadow: 0 0 70px rgba(0, 0, 0, 0.35);
            padding: 48px 64px;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .brand {
            text-align: center;
            font-family: 'Playfair Display', serif;
            font-weight: 600;
            font-size: 22px;
            letter-spacing: 4px;
            color: var(--text);
            text-transform: uppercase;
            margin: 0 0 8px;
        }

        .logo {
            display: block;
            width: 150px;
            max-width: 60%;
            margin: 0 auto 8px;
        }

        h1.heading {
            text-align: center;
            font-family: 'Playfair Display', serif;
            font-weight: 500;
            font-size: 34px;
            color: var(--accent);
            margin: 0 0 28px;
        }

        .success-banner {
            background: #EFEAE0;
            color: #6B5A2E;
            border: 1px solid var(--accent);
            padding: 10px 12px;
            font-size: 13px;
            margin-bottom: 20px;
            text-align: center;
        }

        .validation-summary {
            color: #b00020;
            font-size: 13px;
            margin-bottom: 16px;
            text-align: center;
        }

        .form-group {
            margin-bottom: 26px;
        }

        .form-group label {
            display: block;
            font-family: 'Inter', sans-serif;
            font-size: 11px;
            font-weight: 600;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            color: var(--muted);
            margin-bottom: 10px;
        }

        .form-group input {
            width: 100%;
            border: none;
            border-bottom: 1px solid var(--muted);
            background: transparent;
            padding: 4px 2px 10px;
            font-family: 'Inter', sans-serif;
            font-size: 15px;
            color: var(--text);
            outline: none;
        }

        .form-group input::placeholder {
            color: #B8B8B2;
        }

        .form-group input:focus {
            border-bottom-color: var(--accent);
        }

        .password-wrapper {
            position: relative;
        }

        .password-wrapper input {
            padding-right: 30px;
        }

        .toggle-password {
            position: absolute;
            top: 0;
            right: 0;
            bottom: 10px;
            display: flex;
            align-items: center;
            background: none;
            border: none;
            padding: 0;
            cursor: pointer;
            color: var(--muted);
        }

        .toggle-password:hover {
            color: var(--text);
        }

        .toggle-password svg {
            width: 18px;
            height: 18px;
        }

        .btn-submit {
            width: 100%;
            padding: 15px;
            border: none;
            background: var(--text);
            color: var(--bg);
            font-family: 'Inter', sans-serif;
            font-size: 13px;
            font-weight: 600;
            letter-spacing: 2px;
            text-transform: uppercase;
            cursor: pointer;
            margin-top: 6px;
        }

        .btn-submit:hover {
            background: #333;
        }

        .links {
            margin-top: 22px;
            text-align: center;
        }

        .links a {
            display: block;
            font-family: 'Inter', sans-serif;
            font-size: 11px;
            font-weight: 500;
            letter-spacing: 1px;
            text-transform: uppercase;
            color: var(--muted);
            text-decoration: underline;
            margin-top: 14px;
        }

        .links a:hover {
            color: var(--text);
        }
    </style>
</head>
<body>
    <div class="auth-panel">
        <div class="brand">QRemember</div>
        <img src="/images/logo.png" alt="QRemember logo" class="logo" />

        <h1 class="heading">Log In</h1>

        @if (Model.Registered)
        {
            <div class="success-banner">Account created successfully. Please log in.</div>
        }

        <form method="post">
            <div asp-validation-summary="All" class="validation-summary"></div>

            <div class="form-group">
                <label asp-for="Email">Email Address</label>
                <input asp-for="Email" type="email" placeholder="test@example.com" />
            </div>

            <div class="form-group">
                <label asp-for="Password">Password</label>
                <div class="password-wrapper">
                    <input asp-for="Password" type="password" placeholder="" />
                    <button type="button" class="toggle-password" aria-label="Show password">
                        <svg class="icon-eye" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
                            <circle cx="12" cy="12" r="3"></circle>
                        </svg>
                        <svg class="icon-eye-off" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none">
                            <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19M14.12 14.12a3 3 0 1 1-4.24-4.24"></path>
                            <line x1="1" y1="1" x2="23" y2="23"></line>
                        </svg>
                    </button>
                </div>
            </div>

            <button type="submit" class="btn-submit">Log In</button>

            <div class="links">
                <a href="#">Forgot password?</a>
                <a asp-page="Register">Don't have an account yet?</a>
            </div>
        </form>
    </div>

    <script>
        document.querySelectorAll('.toggle-password').forEach(function (btn) {
            btn.addEventListener('click', function () {
                var wrapper = btn.closest('.password-wrapper');
                var input = wrapper.querySelector('input');
                var eye = btn.querySelector('.icon-eye');
                var eyeOff = btn.querySelector('.icon-eye-off');
                var isHidden = input.type === 'password';

                input.type = isHidden ? 'text' : 'password';
                eye.style.display = isHidden ? 'none' : '';
                eyeOff.style.display = isHidden ? '' : 'none';
                btn.setAttribute('aria-label', isHidden ? 'Hide password' : 'Show password');
            });
        });
    </script>
</body>
</html>
