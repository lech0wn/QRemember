@page "{code}"
@model EventGalleryModel
@{
    ViewData["Title"] = Model.EventName;
    Layout = null;

    var photos = Model.Photos.ToList();
    var rowIndex = 0;
    var photoIndex = 0;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"]</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet" />
    <style>
        :root {
            --text: #1C1C1C;
            --muted: #6B6B6B;
            --hero-overlay: rgba(0, 0, 0, 0.45);
            --page-bg: #ffffff;
        }

        * {
            box-sizing: border-box;
        }

        html, body {
            margin: 0;
            min-height: 100%;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: var(--page-bg);
            color: var(--text);
        }

        .hero {
            position: relative;
            min-height: 220px;
            padding: 40px 32px 36px;
            display: flex;
            align-items: flex-end;
            justify-content: space-between;
            gap: 24px;
            background-color: #2a2a2a;
            background-size: cover;
            background-position: center;
        }

        .hero::before {
            content: "";
            position: absolute;
            inset: 0;
            background: var(--hero-overlay);
        }

        .hero-main,
        .share-link {
            position: relative;
            z-index: 1;
        }

        .hero-title {
            margin: 0 0 8px;
            font-size: clamp(28px, 5vw, 42px);
            font-weight: 700;
            color: #fff;
            line-height: 1.1;
        }

        .hero-date {
            margin: 0 0 6px;
            font-size: 18px;
            font-weight: 600;
            color: #fff;
        }

        .hero-organizer {
            margin: 0;
            font-size: 14px;
            font-weight: 600;
            color: rgba(255, 255, 255, 0.92);
        }

        .share-link {
            flex-shrink: 0;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 8px;
            text-decoration: none;
            color: var(--text);
        }

        .share-btn {
            width: 72px;
            height: 72px;
            border-radius: 16px;
            background: #fff;
            border: none;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 8px 24px rgba(0, 0, 0, 0.25);
            cursor: pointer;
        }

        .share-btn svg {
            width: 32px;
            height: 32px;
        }

        .share-label {
            font-size: 13px;
            font-weight: 700;
            color: #fff;
        }

        .gallery {
            max-width: 1100px;
            margin: 0 auto;
            padding: 32px 24px 80px;
        }

        .gallery-row {
            display: grid;
            gap: 20px;
            margin-bottom: 28px;
        }

        .gallery-row.cols-2 {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .gallery-row.cols-3 {
            grid-template-columns: repeat(3, minmax(0, 1fr));
        }

        .photo-card img {
            width: 100%;
            display: block;
            border-radius: 4px;
            aspect-ratio: 4 / 3;
            object-fit: cover;
            background: #e8e8e8;
        }

        .photo-meta {
            margin-top: 12px;
        }

        .photo-author {
            margin: 0 0 6px;
            font-size: 14px;
            font-weight: 700;
        }

        .photo-caption {
            margin: 0;
            font-size: 13px;
            line-height: 1.55;
            color: var(--muted);
        }

        .empty-state {
            text-align: center;
            padding: 48px 16px 24px;
            color: var(--muted);
            font-size: 15px;
        }

        @@media (max-width: 768px) {
            .hero {
                flex-direction: column;
                align-items: flex-start;
                padding: 28px 20px;
            }

            .share-link {
                align-self: flex-end;
                flex-direction: row;
                gap: 12px;
            }

            .share-label {
                color: #fff;
            }

            .gallery-row.cols-2,
            .gallery-row.cols-3 {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>
    <header class="hero" style="@(Model.HeroImageUrl is not null ? $"background-image: url('{Model.HeroImageUrl}');" : "")">
        <div class="hero-main">
            <h1 class="hero-title">@Model.EventName</h1>
            <p class="hero-date">@Model.EventDateDisplay</p>
            <p class="hero-organizer">by @Model.OrganizerDisplayName</p>
        </div>
        <a asp-page="/Shared/Gallery/PhotoUpload" asp-route-code="@Model.EventCode" class="share-link" aria-label="Share a photo">
            <span class="share-btn" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"></path>
                    <circle cx="12" cy="13" r="4"></circle>
                    <line x1="19" y1="8" x2="19" y2="5"></line>
                    <line x1="19" y1="5" x2="22" y2="5"></line>
                </svg>
            </span>
            <span class="share-label">Share</span>
        </a>
    </header>

    <main class="gallery">
        @if (photos.Count == 0)
        {
            <p class="empty-state">No photos yet. Tap Share to upload the first one.</p>
        }
        else
        {
            while (photoIndex < photos.Count)
            {
                var cols = rowIndex % 2 == 0 ? 2 : 3;
                var rowClass = cols == 2 ? "cols-2" : "cols-3";
                var take = Math.Min(cols, photos.Count - photoIndex);
                var rowPhotos = photos.GetRange(photoIndex, take);

                <div class="gallery-row @rowClass">
                    @foreach (var photo in rowPhotos)
                    {
                        <article class="photo-card">
                            <img src="@photo.ImageUrl" alt="Photo by @photo.AuthorName" loading="lazy" />
                            <div class="photo-meta">
                                <p class="photo-author">by @photo.AuthorName</p>
                                @if (!string.IsNullOrWhiteSpace(photo.Caption))
                                {
                                    <p class="photo-caption">@photo.Caption</p>
                                }
                            </div>
                        </article>
                    }
                </div>

                photoIndex += take;
                rowIndex++;
            }
        }
    </main>
</body>
</html>
